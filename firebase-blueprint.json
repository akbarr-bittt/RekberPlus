{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Rekbrio platform",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "name": {
          "type": "string",
          "description": "The user's full name"
        },
        "pin": {
          "type": "string",
          "description": "6-digit security PIN for transactions"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Whether the user has enabled notifications"
        },
        "phone": {
          "type": "string",
          "description": "User's phone number"
        },
        "bankName": {
          "type": "string",
          "description": "User's bank name for withdrawals"
        },
        "bankAccount": {
          "type": "string",
          "description": "User's bank account number"
        },
        "bankAccountName": {
          "type": "string",
          "description": "User's bank account holder name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "name", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An escrow transaction between a buyer and a seller",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the transaction"
        },
        "description": {
          "type": "string",
          "description": "Description of the goods or services"
        },
        "price": {
          "type": "number",
          "description": "Price of the goods or services"
        },
        "fee": {
          "type": "number",
          "description": "Platform fee (2%)"
        },
        "total": {
          "type": "number",
          "description": "Total amount to be paid (price + fee)"
        },
        "creatorId": {
          "type": "string",
          "description": "UID of the user who created the transaction"
        },
        "creatorRole": {
          "type": "string",
          "enum": ["buyer", "seller"],
          "description": "Role of the creator"
        },
        "buyerId": {
          "type": "string",
          "description": "UID of the buyer"
        },
        "sellerId": {
          "type": "string",
          "description": "UID of the seller"
        },
        "status": {
          "type": "string",
          "enum": [
            "waiting_payment",
            "funds_held",
            "processing",
            "shipped",
            "completed",
            "cancelled",
            "disputed",
            "TERM_ESCROW_ACTIVE"
          ],
          "description": "Current status of the transaction"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction was last updated"
        },
        "isClaimed": {
          "type": "boolean",
          "description": "Whether the seller has claimed the funds after completion"
        },
        "isEscrowBerjangka": {
          "type": "boolean",
          "description": "Whether this is a termed escrow"
        },
        "escrowDuration": {
          "type": "number",
          "description": "Duration in days"
        },
        "escrowSecurityFee": {
          "type": "number",
          "description": "Extra fee for termed escrow"
        },
        "escrowReleaseDate": {
          "type": "string",
          "format": "date-time",
          "description": "Estimated release date"
        }
      },
      "required": [
        "title",
        "description",
        "price",
        "fee",
        "total",
        "creatorId",
        "creatorRole",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global platform settings",
      "type": "object",
      "properties": {
        "adminPhone": { "type": "string" },
        "platformFee": { "type": "number" },
        "securityFeePerDay": { "type": "number" },
        "platform_bank_name": { "type": "string" },
        "platform_account_number": { "type": "string" },
        "platform_account_holder": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores escrow transactions"
    }
  }
}
